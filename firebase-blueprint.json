{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role assignment",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "SALES_AGENT"] },
        "name": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Product catalog item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "modelNumber": { "type": "string" },
        "category": { "type": "string" },
        "sellingPrice": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["name", "sku", "sellingPrice"]
    },
    "Container": {
      "title": "Container",
      "description": "Import shipment unit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "arrivalDate": { "type": "string", "format": "date-time" },
        "shippingCosts": { "type": "number" },
        "customsFees": { "type": "number" },
        "totalLandedCost": { "type": "number" },
        "status": { "type": "string", "enum": ["PENDING", "ARRIVED", "DEPLETED"] }
      },
      "required": ["name", "arrivalDate", "status"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Stock of a product from a specific container",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "containerId": { "type": "string" },
        "quantity": { "type": "number" },
        "initialQuantity": { "type": "number" },
        "unitCost": { "type": "number" }
      },
      "required": ["productId", "containerId", "quantity", "unitCost"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Sales transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "agentId": { "type": "string" },
        "customerName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "totalAmount", "agentId", "timestamp"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "System action logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "/containers/{containerId}": {
      "schema": "Container",
      "description": "Shipments"
    },
    "/inventory/{inventoryId}": {
      "schema": "InventoryItem",
      "description": "Stock items linked to containers"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales records"
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "System logs"
    }
  }
}
